
@page "/OpretBooking"
@rendermode InteractiveServer
@using BookRight.Facade.Interfaces
@using BookRight.Facade.DTOs.GetAllCustomersDTOs
@using BookRight.Facade.DTOs.CreateCustomerDTOs
@inject ICreateTherapistUseCase CreateTherapistUseCase
@inject ICreateCustomerUseCase CreateCustomerUseCase
@inject IGetAllTherapistsUseCase GetAllTherapistsUseCase
@inject IGetAllCustomersUseCase GetAllCustomersUseCase

<!--
    Siden benytter Bootstrap-klasser til styling
-->

<PageTitle>Opret Booking</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Opret Booking</h1>

    <div class="row">

        <!-- THERAPIST -->
        <article class="col-md-6">
            <section class="card">
                <div class="card-header">
                    <h4 class="mb-0">Opret Booking</h4>
                </div>

                <div>
                    <select class="form-select" @bind="selectedCustomerId">
						<option value="">Vælg kunde</option>
						@foreach (var customer in customers)
						{
							<option value="@customer.Id">@customer.FirstName @customer.LastName</option>
						}
                    </select>
                </div>

                <div>
                    <select class="form-select" @bind="selectedClinicId">
                        <option value="">Vælg kunde</option>
                        @foreach (var clinic in clinics)
                        {
                            <option value="@clinic.Id">@clinic.Name</option>
                        }
                    </select>
                </div>


                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label">Fornavn</label>
                        <input class="form-control" @bind="therapistFirstName" placeholder="Skriv fornavn her..." />
                    </div>
               

                    <button class="btn btn-primary" @onclick="CreateTherapist">Opret Therapist</button>

                    @if (!string.IsNullOrEmpty(therapistMessage))
                    {
                        <div class="alert @therapistAlertClass mt-3">@therapistMessage</div>
                    }
                </div>

            </section>
        </article>

     </div>

    <!-- CUSTOMER TABLE -->
    <div class="row mt-4">
        <article class="col-12">
            <section class="card">
                <div class="card-header">
                    <h4 class="mb-0">Bookinger</h4>
                </div>
                <div class="card-body">
                    @if (!customers.Any())
                    {
                        <p class="text-muted">Ingen bookinger oprettet endnu.</p>
                    }
                    else
                    {
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Navn</th>
                                    <th>Email</th>
                                    <th>Telefon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var booking in bookings)
                                {
                                    <tr>
                                        <td>@booking.customer.FirstName @booking.customer.LastName</td>
                                        <td>@booking.TimeSlot.StartTime - @booking.TimeSlot.EndTime</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </section>
        </article>
    </div>

</div>

@code {
    // Therapist form fields. Holds the data that you enter into the HTML. HTML in this context just being the fields you type stuff in.
    private string selectedCustomerId = "";
    private string selectedClinicId = "";
   

    // Lister der holder data fra GetAll, til at vise nyligt oprettede entities
    private IReadOnlyList<GetAllCustomersResponse> customers = new List<GetAllCustomersResponse>();
    private IReadOnlyList<GetAllClinicsResponse> clinics = new List<GetAllClinicsResponse>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        clinics = await GetAllClinicsUseCase.ExecuteAsync();
        customers = await GetAllCustomersUseCase.ExecuteAsync();
    }

   
    private async Task CreateCustomer()
    {
        try
        {
            var request = new CreateCustomerRequest(
            customerFirstName,
            customerLastName,
            customerEmail,
            customerPhone,
            customerDateOfBirth,
            customerHealthNotes,
            customerPreferredTherapistId
            );

            var response = await CreateCustomerUseCase.ExecuteAsync(request);
            customerMessage = $"Kunde oprettet med ID: {response.customerId}";
            customerAlertClass = "alert-success";

            // Nulstil felter efter oprettelse
            customerFirstName = "";
            customerLastName = "";
            customerPhone = "";

            await LoadData();
        }
        catch (Exception ex)
        {
            customerMessage = $"Fejl: {ex.Message}";
            customerAlertClass = "alert-danger";
        }
    }
}